generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== 社員マスタ ==========
model Employee {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  department  String   @default("")
  position    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  visits      Visit[]

  @@index([isActive])
  @@index([department])
}

// ========== 来客記録 ==========
model Visit {
  id             String      @id @default(cuid())
  visitorName    String
  visitorCompany String?
  purpose        String      // MEETING, INTERVIEW, DELIVERY, OTHER
  employeeId     String?
  status         String      @default("CHECKED_IN") // CHECKED_IN, NOTIFIED, COMPLETED

  // 担当者の応答
  response       String?     // "on_my_way", "please_wait", "rejected"
  responseAt     DateTime?

  // 通話
  callStatus     String?     // "ringing", "connected", "ended"
  callStartedAt  DateTime?
  callEndedAt    DateTime?

  notifiedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime    @default(now())

  employee       Employee?   @relation(fields: [employeeId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([employeeId])
}
