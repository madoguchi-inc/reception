// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

// Organization Models
model Organization {
  id               String   @id @default(cuid())
  name             String
  logo             String?
  primaryColor     String   @default("#3b82f6")
  welcomeMessage   String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  locations         Location[]
  departments       Department[]
  employees         Employee[]
  meetingRooms      MeetingRoom[]
  appointments      Appointment[]
  settings          OrganizationSettings?

  @@index([name])
}

model Location {
  id             String   @id @default(cuid())
  name           String
  address        String?  @db.Text
  organizationId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments    Department[]
  employees      Employee[]
  meetingRooms   MeetingRoom[]
  appointments   Appointment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isActive])
}

model Department {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  locationId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  employees    Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([locationId])
}

model Employee {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  departmentId     String
  organizationId   String
  locationId       String?
  position         String?
  googleChatSpaceId String?
  isActive         Boolean  @default(true)
  avatarUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  department       Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location         Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  appointments     Appointment[]
  notifications    Notification[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([departmentId])
  @@index([locationId])
  @@index([isActive])
}

model MeetingRoom {
  id              String   @id @default(cuid())
  name            String
  capacity        Int      @default(1)
  floor           String?
  locationId      String
  organizationId  String
  googleCalendarId String?
  facilities      String[] @default([])
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location        Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@unique([organizationId, locationId, name])
  @@index([organizationId])
  @@index([locationId])
  @@index([isActive])
}

enum VisitPurpose {
  MEETING
  INTERVIEW
  DELIVERY
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id                String              @id @default(cuid())
  visitorName       String
  visitorCompany    String?
  visitorEmail      String?
  visitorPhone      String?
  purpose           VisitPurpose
  purposeNote       String?
  employeeId        String
  organizationId    String
  locationId        String
  meetingRoomId     String?
  qrToken           String              @unique
  status            AppointmentStatus   @default(SCHEDULED)
  googleEventId     String?
  scheduledAt       DateTime
  checkedInAt       DateTime?
  checkedOutAt      DateTime?
  notes             String?             @db.Text
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  employee          Employee            @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location          Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  meetingRoom       MeetingRoom?        @relation(fields: [meetingRoomId], references: [id], onDelete: SetNull)
  visitLogs         VisitLog[]
  notifications     Notification[]

  @@index([organizationId])
  @@index([employeeId])
  @@index([locationId])
  @@index([meetingRoomId])
  @@index([qrToken])
  @@index([status])
  @@index([scheduledAt])
}

enum VisitAction {
  CHECK_IN
  CHECK_OUT
  NOTIFICATION_SENT
  RESPONSE_RECEIVED
  CANCELLED
}

model VisitLog {
  id            String      @id @default(cuid())
  appointmentId String
  action        VisitAction
  performedBy   String?
  details       String?     @db.Text
  createdAt     DateTime    @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([action])
  @@index([createdAt])
}

enum NotificationChannel {
  GOOGLE_CHAT
  EMAIL
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  RESPONDED
  FAILED
}

model Notification {
  id            String               @id @default(cuid())
  appointmentId String
  employeeId    String
  channel       NotificationChannel
  status        NotificationStatus   @default(PENDING)
  response      String?
  sentAt        DateTime?
  respondedAt   DateTime?
  errorMessage  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  appointment   Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  employee      Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([employeeId])
  @@index([status])
  @@index([channel])
}

model OrganizationSettings {
  id                      String   @id @default(cuid())
  organizationId          String   @unique
  defaultLanguage         String   @default("ja")
  allowedPurposes         String[] @default(["MEETING", "INTERVIEW", "DELIVERY", "OTHER"])
  requireVisitorCompany   Boolean  @default(true)
  requireVisitorEmail     Boolean  @default(false)
  requireVisitorPhone     Boolean  @default(false)
  notificationChannels    String[] @default(["GOOGLE_CHAT"])
  googleChatWebhookUrl    String?  @db.Text
  googleChatBotToken      String?  @db.Text
  googleClientId          String?
  googleClientSecret      String?
  smtpHost                String?
  smtpPort                Int?
  smtpUser                String?
  smtpPass                String?  @db.Text
  smtpFrom                String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
